# ─── App ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=kari
LOG_LEVEL=info
# Comma-separated list, or * for all (dev only)
CORS_ORIGINS=*

# ─── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=kari
POSTGRES_PASSWORD=kari
POSTGRES_DB=kari
# Never enable synchronize outside local/staging — use migrations in prod
DB_SYNCHRONIZE=false
DB_LOGGING=false

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (generate strong secrets for staging/production) ──────────────────
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_TTL=30d

# ─── Rate limiting ─────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ─── Providers (leave blank to use no-op/log implementations in dev) ───────
# Payments — Paystack
PAYSTACK_SECRET_KEY=
# Identity / NIN — Dojah
DOJAH_API_KEY=
DOJAH_APP_ID=
# SMS — Termii
TERMII_API_KEY=
TERMII_SENDER_ID=Kari
# WhatsApp + masked voice — Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
# Storage + liveness — AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=
# Maps / traffic — Google
GOOGLE_MAPS_API_KEY=
# Push — Expo
EXPO_ACCESS_TOKEN=
