{
  "expo": {
    "name": "Kari",
    "slug": "kari",
    "scheme": "kari",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#000D26",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#000D26",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kari.rider",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.kari.rider",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000D26"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kari uses your location to find rides near you."
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Kari uses your camera for a quick selfie to confirm it's really you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b846e15a-53ec-49ac-bea2-477d080677e9"
      },
      "apiBaseUrl": "https://karibackend-production.up.railway.app",
      "socketUrl": "https://karibackend-production.up.railway.app",
      "googleWebClientId": "903491688476-0j6qpegdjijhos887pl9q6i3dor5uq50.apps.googleusercontent.com",
      "googleIosClientId": "903491688476-uank45rgrq74ucfek7hc29i2c3cb7tpn.apps.googleusercontent.com",
      "googleAndroidClientId": "903491688476-s6lv41lpkdr84vb64foa9pt5f1b8ilbn.apps.googleusercontent.com"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b846e15a-53ec-49ac-bea2-477d080677e9"
    }
  }
}
