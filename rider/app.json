{
  "expo": {
    "name": "Kari",
    "slug": "kari",
    "scheme": "kari",
    "version": "0.1.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "backgroundColor": "#000D26",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#000D26",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kari.rider"
    },
    "android": {
      "package": "com.kari.rider",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000D26"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kari uses your location to find rides near you."
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Kari uses your camera for a quick selfie to confirm it's really you."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b846e15a-53ec-49ac-bea2-477d080677e9"
      },
      "apiBaseUrl": "https://karibackend-production.up.railway.app",
      "socketUrl": "https://karibackend-production.up.railway.app",
      "googleWebClientId": "",
      "googleIosClientId": ""
    }
  }
}
